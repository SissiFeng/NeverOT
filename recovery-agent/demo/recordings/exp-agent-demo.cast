[0.000, "o", "\u001b[1m\u001b[0;36m║\u001b[0m  \u001b[1mSCENARIO 3: Communication Timeout → Automatic Retry\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Inject TIMEOUT fault — device becomes temporarily unresponsive\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Agent should detect postcondition failure, RETRY, and recover\u001b[0m\r\n\r\n"]
