[0.000, "o", "\r\n\u001b[1m\u001b[0;36m\r\n"]
[0.010, "o", "  ╔═══════════════════════════════════════════════════════════╗\r\n  ║                                                           ║\r\n  ║   ███████╗██╗  ██╗██████╗       █████╗  ██████╗ ████████╗ ║\r\n  ║   ██╔════╝╚██╗██╔╝██╔══██╗     ██╔══██╗██╔════╝ ╚══██╔══╝ ║\r\n  ║   █████╗   ╚███╔╝ ██████╔╝     ███████║██║  ███╗   ██║    ║\r\n  ║   ██╔══╝   ██╔██╗ ██╔═══╝      ██╔══██║██║   ██║   ██║    ║\r\n  ║   ███████╗██╔╝ ██╗██║          ██║  ██║╚██████╔╝   ██║    ║\r\n  ║   ╚══"]
[0.000, "o", "════╝╚═╝  ╚═╝╚═╝          ╚═╝  ╚═╝ ╚═════╝    ╚═╝    ║\r\n  ║                                                           ║\r\n  ║   Recovery-Aware Execution Agent for Lab Hardware         ║\r\n  ║   Autonomous Sense → Decide → Act Loop                    ║\r\n  ║                                                           ║\r\n  ╚═══════════════════════════════════════════════════════════╝\r\n"]
[0.000, "o", "\u001b[0m\r\n"]
[0.001, "o", "  \u001b[2mThis demo showcases the agent's autonomous disaster recovery\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2mcapabilities when managing laboratory hardware.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  \u001b[2mThe agent follows a continuous loop:\u001b[0m\r\n"]
[0.000, "o", "    \u001b[1mSENSE\u001b[0m \u001b[2m→\u001b[0m \u001b[1mDECIDE\u001b[0m \u001b[2m→\u001b[0m \u001b[1mACT\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2mdetecting faults, classifying errors, and executing safe recoveries.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m╔══════════════════════════════════════════════════════════════╗\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m║\u001b[0m  \u001b[1mSCENARIO 1: Normal Operation (Happy Path)\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Run the agent with NO faults — heater reaches 120°C normally\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Expected: set_temperature → wait → shutdown. All checks pass.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  \u001b[0;32m$ \u001b[0m"]
[0.000, "o", "python3 -m exp_agent.cli.run_sim --fault-mode none --target-temp 120 --seed 42"]
[0.000, "o", "\r\n"]
[0.092, "o", "Random Seed: 42\r\nConfiguration: Fault Mode=none, Target Temp=120.0\r\n"]
[0.000, "o", "=== Supervisor Loop Started ===\r\n"]
[0.000, "o", "Goal: Heat to 120.0°C\r\nPostconditions enabled: checking device state using Polling (PostCheck) module\r\n"]
[0.000, "o", "\r\n--- Step 1 ---\r\n"]
[0.000, "o", "  [SimHeater] Tick=1 T=25.0 (Target=25.0)\r\n"]
[0.000, "o", "ActionProposed: set_temperature {'temperature': 120.0}\r\n[Executor] Verifying action: set_temperature {'temperature': 120.0}...\r\n[Executor] Executing on device heater_1...\r\n[heater_1] Setting target to 120.0\r\n"]
[0.001, "o", "[PostCheck] Verifying 2 conditions for set_temperature\r\n"]
[5.045, "o", "[PostCheck] All conditions met.\r\n"]
[0.000, "o", "[Executor] Action set_temperature completed and verified.\r\n"]
[0.506, "o", "\r\n--- Step 2 ---\r\n"]
[0.000, "o", "  [SimHeater] Tick=2 T=120.0 (Target=120.0)\r\n"]
[0.000, "o", "ActionProposed: wait {'duration': 5}\r\n[Executor] Verifying action: wait {'duration': 5}...\r\n"]
[0.000, "o", "[Executor] Executing on device heater_1...\r\n"]
[0.000, "o", "[heater_1] Waiting for 5 seconds... (Simulated by sleep in logic)\r\n"]
[0.000, "o", "[Executor] Action wait completed and verified.\r\n"]
[0.500, "o", "\r\n--- Step 3 ---\r\n"]
[0.001, "o", "  [SimHeater] Tick=3 T=120.0 (Target=120.0)\r\nPlan finished. Current Temp: 120.0\r\nPerforming Safe Shutdown Sequence...\r\n"]
[0.000, "o", "[Shutdown] Executing cool_down...\r\n"]
[0.000, "o", "[Executor] Verifying action: cool_down {}...\r\n"]
[0.000, "o", "[Executor] Executing on device heater_1...\r\n"]
[0.000, "o", "[heater_1] Cooling down to 25.0\r\n"]
[0.000, "o", "[PostCheck] Verifying 2 conditions for cool_down\r\n"]
[0.000, "o", "[PostCheck] All conditions met.\r\n[Executor] Action cool_down completed and verified.\r\n"]
[0.000, "o", "Shutdown complete. Terminal state verified safe.\r\n"]
[0.031, "o", "\r\n  \u001b[0;32m✓ Normal operation completed successfully\u001b[0m\r\n  \u001b[2m  All postconditions met, safe shutdown performed\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1m\u001b[0;36m╔══════════════════════════════════════════════════════════════╗\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m║\u001b[0m  \u001b[1mSCENARIO 2: Temperature Overshoot → Safety Violation\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m\u001b[0;36m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Inject OVERSHOOT fault — temperature exceeds safety limit (130°C)\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2m\u001b[0;35m# Agent must detect violation, classify as UNSAFE, and ABORT safely\u001b[0m\r\n\r\n"]
[0.000, "o", "  \u001b[0;32m$ \u001b[0m"]
[0.000, "o", "python3 -m exp_agent.cli.run_sim --fault-mode overshoot --target-temp 120 --seed 42"]
