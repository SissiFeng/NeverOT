[0.000, "o", "\u001b[1m============================================================\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m  Exp-Agent: Recovery-Aware Execution Agent\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m  Test Suite Demo вҖ” 29 Tests\u001b[0m\r\n\u001b[1m============================================================\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[0;36mTest Coverage:\u001b[0m\r\n"]
[0.000, "o", "  1. Guardrails & Safety Checks\r\n"]
[0.000, "o", "  2. Error Classification (overshoot, sensor_fail, timeout)\r\n"]
[0.000, "o", "  3. Signature Analysis (drift, stall, oscillation, stable)\r\n"]
[0.000, "o", "  4. Recovery Decisions (retry, skip, abort, degrade)\r\n  5. Policy Integration (full escalation sequence)\r\n"]
[0.000, "o", "  6. Workflow Execution (step cursor, stage tracking)\r\n"]
[0.000, "o", "  7. SKIP Decision (optional step failure вҶ’ skip)\r\n  8. DEGRADE Cascade (PlanPatch вҶ’ downstream updates)\r\n"]
[0.000, "o", "  9. Retry Budget (exhaustion вҶ’ on_failure fallback)\r\n\r\n"]
