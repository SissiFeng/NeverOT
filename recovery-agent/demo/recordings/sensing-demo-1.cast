[0.205, "o", "\r\n\u001b[1m\u001b[0;36m══════════════════════════════════════════════════════════════════════\u001b[0m\r\n\u001b[1m\u001b[0;36m  Demo 1: Blind Recovery vs Sensing-Aware Recovery\u001b[0m\r\n\u001b[1m\u001b[0;36m══════════════════════════════════════════════════════════════════════\u001b[0m\r\n\r\n\r\n\u001b[1m\u001b[1;33m────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[1m\u001b[1;33mStep A: OLD System - Blind Recovery Agent\u001b[0m\r\n\u001b[1m\u001b[1;33m────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n  \u001b[2m# Without sensing layer, agent only"]
[0.000, "o", " knows 'something failed'\u001b[0m\r\n\r\n"]
