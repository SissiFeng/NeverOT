# ============================================================
# OTbot Environment Configuration
# Copy this file to .env and edit values
# ============================================================

# ── Adapter Mode ─────────────────────────────────────────
# simulated = no real hardware (default for development)
# live      = connect to real instruments
ADAPTER_MODE=simulated
ADAPTER_DRY_RUN=true

# ── Hardware Addresses ───────────────────────────────────
# OT-2 robot IP (communicates via HTTP API)
ROBOT_IP=<your-robot-ip>

# Serial ports: set to "auto" for auto-detection, or specify
# On Windows/WSL2: COM3, COM4, etc. or /dev/ttyUSB0 in WSL
# On Linux/Mac:    /dev/ttyUSB0, /dev/ttyACM0, etc.
RELAY_PORT=auto
SQUIDSTAT_PORT=auto

# ── LLM Configuration ───────────────────────────────────
# mock     = no LLM calls (default for testing)
# anthropic = Claude API
# openai   = OpenAI API
LLM_PROVIDER=mock
LLM_API_KEY=<your-llm-api-key>
LLM_MODEL=claude-sonnet-4-20250514

# ── Port Mapping ─────────────────────────────────────────
OTBOT_PORT=8000
RECOVERY_PORT=8001
